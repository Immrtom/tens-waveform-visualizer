# TENS Waveform Generator - Mode 1 Example
import numpy as np
import matplotlib.pyplot as plt

# Mode parameters
mode_number = 1
vpp_single = 95
vpp_double = 58
frequency = 15  # Hz

# Time array: 0 to 0.2 seconds
t = np.linspace(0, 0.2, 1000)

# Calculate sine wave data strings
wave_single = (vpp_single / 2) * np.sin(2 * np.pi * frequency * t)
wave_double = (vpp_double / 2) * np.sin(2 * np.pi * frequency * t)

# Plotting
plt.figure(figsize=(10, 5))
plt.plot(t, wave_single, label=f'Single-Hole (Vpp={vpp_single}V)', color='blue', linewidth=2)
plt.plot(t, wave_double, label=f'Double-Hole (Vpp={vpp_double}V)', color='orange', linestyle='--', linewidth=2)

plt.title(f'TENS Device Waveform Simulation - Mode {mode_number} ({frequency} Hz)')
plt.xlabel('Time (seconds)')
plt.ylabel('Voltage (V)')
plt.axhline(0, color='black', linewidth=0.5, linestyle=':')
plt.grid(True, linestyle=':', alpha=0.6)
plt.legend()
plt.tight_layout()
plt.show()
